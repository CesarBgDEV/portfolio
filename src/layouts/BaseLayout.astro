---
import '../styles/global.css';

export interface Props {
  lang: 'es' | 'en';
  title?: string;
  description?: string;
}

const {
  lang,
  title = 'César Balderas Guillén — Software Engineer & CTO',
  description = lang === 'es'
    ? 'Ingeniero de Software, Co-Fundador y CTO de Valion Digital Consulting. Especializado en desarrollo web full stack, arquitectura de sistemas y despliegue cloud.'
    : 'Software Engineer, Co-Founder and CTO at Valion Digital Consulting. Specialized in full stack web development, system architecture and cloud deployment.',
} = Astro.props;

const ogLocale = lang === 'es' ? 'es_MX' : 'en_US';
const canonicalURL = new URL(Astro.url.pathname, 'https://tudominio.com');
---

<!DOCTYPE html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href="https://tudominio.com/es/" />
    <link rel="alternate" hreflang="en" href="https://tudominio.com/en/" />
    <link rel="alternate" hreflang="x-default" href="https://tudominio.com/es/" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap 5 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />

    <!-- Devicons (tech icons) -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.16.0/devicon.min.css"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme init (before CSS paint — prevents flash) -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const theme = saved || preferred;
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <!-- Scroll progress indicator -->
    <div class="scroll-progress" aria-hidden="true"></div>

    <slot />

    <!-- Bootstrap JS Bundle -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmBT0bHyVdZejMsAUnIJHkp2z9xh"
      crossorigin="anonymous"
    ></script>

    <!-- Interactivity: theme toggle + scroll reveal + skill bars -->
    <script>
      // ── Theme toggle ──────────────────────────────────────────
      const html = document.documentElement;
      const toggleBtn = document.getElementById('theme-toggle');
      const iconSun = document.getElementById('icon-sun');
      const iconMoon = document.getElementById('icon-moon');

      function applyTheme(theme: string) {
        html.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        if (iconSun && iconMoon) {
          iconSun.style.display = theme === 'light' ? 'none' : 'block';
          iconMoon.style.display = theme === 'light' ? 'block' : 'none';
        }
      }

      // Init icon state
      applyTheme(html.getAttribute('data-theme') || 'dark');

      // Enable smooth transitions after first paint
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          html.classList.add('theme-ready');
        });
      });

      toggleBtn?.addEventListener('click', () => {
        const current = html.getAttribute('data-theme') || 'dark';
        const next = current === 'dark' ? 'light' : 'dark';
        toggleBtn.classList.add('spinning');
        setTimeout(() => toggleBtn.classList.remove('spinning'), 400);
        applyTheme(next);
      });

      // ── Scroll reveal ─────────────────────────────────────────
      // Elements above the fold get a fast entrance; elements below
      // animate as they scroll into view with a deliberate delay so
      // the user clearly sees the slide-up + blur-out effect.
      const aboveFold = window.innerHeight;

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const rect = el.getBoundingClientRect();
              // Elements already visible on load: no delay, instant reveal
              if (rect.top < aboveFold) {
                el.style.transitionDelay = '0s';
              }
              el.classList.add('revealed');
              revealObserver.unobserve(el);
            }
          });
        },
        // Trigger when element is 100px above the bottom edge — user
        // clearly sees it entering from below.
        { threshold: 0.08, rootMargin: '0px 0px -100px 0px' }
      );

      document.querySelectorAll('[data-reveal]').forEach((el) => {
        revealObserver.observe(el);
      });

      // ── Skill bars ────────────────────────────────────────────
      const skillsSection = document.getElementById('skills');
      if (skillsSection) {
        const skillObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                skillsSection.classList.add('skills-visible');
                skillObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.25 }
        );
        skillObserver.observe(skillsSection);
      }

      // ── Scroll progress bar ───────────────────────────────────
      const progressBar = document.querySelector('.scroll-progress') as HTMLElement | null;
      function updateProgress() {
        const scrolled = window.scrollY;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        const pct = total > 0 ? (scrolled / total) * 100 : 0;
        if (progressBar) progressBar.style.width = `${pct}%`;
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      // ── Parallax hero background ──────────────────────────────
      const heroPre = document.querySelector('.hero-bg-code pre') as HTMLElement | null;
      function updateParallax() {
        if (!heroPre) return;
        const y = window.scrollY;
        const vh = window.innerHeight;
        if (y < vh * 1.2) {
          heroPre.style.transform = `translate(-50%, calc(-50% + ${y * 0.18}px))`;
        }
      }
      window.addEventListener('scroll', updateParallax, { passive: true });
    </script>
  </body>
</html>
