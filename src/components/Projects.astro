---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// icon: devicon class or '' when no devicon available
const iconMap: Record<string, string> = {
  'Django':      'devicon-django-plain colored',
  'MySQL':       'devicon-mysql-plain colored',
  'Bootstrap 5': 'devicon-bootstrap-plain colored',
  'Bootstrap':   'devicon-bootstrap-plain colored',
  'jQuery':      'devicon-jquery-plain colored',
  'Docker':      'devicon-docker-plain colored',
  'Nginx':       'devicon-nginx-plain colored',
  'Astro':       'devicon-astro-plain colored',
  'React':       'devicon-react-plain colored',
  // No devicon for: ReportLab, DataTables, OpenPay, Gunicorn, Resend
};

const projects = [
  {
    emoji: '🥖',
    nameKey: 'proj.1.name',
    descKey: 'proj.1.desc',
    stack: ['Django', 'MySQL', 'Bootstrap 5', 'jQuery', 'Docker', 'ReportLab', 'DataTables'],
    status: 'production' as const,
  },
  {
    emoji: '📋',
    nameKey: 'proj.2.name',
    descKey: 'proj.2.desc',
    stack: ['Django', 'MySQL', 'Bootstrap 5', 'OpenPay', 'Gunicorn', 'Nginx'],
    status: 'production' as const,
  },
  {
    emoji: '🏠',
    nameKey: 'proj.3.name',
    descKey: 'proj.3.desc',
    stack: ['Astro', 'Bootstrap', 'React', 'Resend', 'Docker', 'Nginx'],
    status: 'production' as const,
  },
];
---

<section id="projects" class="section">
  <div class="container">
    <div class="mb-5" data-reveal style="--reveal-delay: 0s">
      <h2 class="section-title">{t('projects.title')}</h2>
      <p class="mt-3" style="color: var(--color-text-muted); font-size: 0.9rem;">
        {t('projects.subtitle')}
      </p>
    </div>

    <div class="row g-4">
      {projects.map((project, i) => (
        <div
          class="col-md-6 col-lg-4"
          data-reveal="scale"
          style={`--reveal-delay: ${i * 0.15}s`}
        >
          <div class="card project-card h-100">
            <div class="project-emoji">{project.emoji}</div>
            <h3 class="project-name">{t(project.nameKey)}</h3>
            <p class="project-desc">{t(project.descKey)}</p>
            <div class="project-footer">
              <div class="chips-wrap mb-3">
                {project.stack.map((s) => (
                  <span class="chip">
                    {iconMap[s] && <i class={iconMap[s]}></i>}
                    {s}
                  </span>
                ))}
              </div>
              <span class={project.status === 'production' ? 'badge-production' : 'badge-development'}>
                {project.status === 'production'
                  ? t('projects.badge.production')
                  : t('projects.badge.development')}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
