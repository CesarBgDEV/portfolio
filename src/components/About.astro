---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// icon: devicon class (sin 'colored' para controlarlo por CSS), or '' si no hay
const stackGroups = [
  {
    label: lang === 'es' ? 'Backend' : 'Backend',
    items: [
      { name: 'Python',      icon: 'devicon-python-plain colored' },
      { name: 'Django',      icon: 'devicon-django-plain colored' },
      { name: 'PHP',         icon: 'devicon-php-plain colored' },
      { name: 'CodeIgniter', icon: 'devicon-codeigniter-plain colored' },
      { name: 'Node.js',     icon: 'devicon-nodejs-plain colored' },
      { name: 'Flask',       icon: 'devicon-flask-original colored' },
    ],
  },
  {
    label: 'Frontend',
    items: [
      { name: 'HTML',       icon: 'devicon-html5-plain colored' },
      { name: 'CSS',        icon: 'devicon-css3-plain colored' },
      { name: 'JavaScript', icon: 'devicon-javascript-plain colored' },
      { name: 'Bootstrap',  icon: 'devicon-bootstrap-plain colored' },
      { name: 'Tailwind',   icon: 'devicon-tailwindcss-plain colored' },
      { name: 'React',      icon: 'devicon-react-plain colored' },
    ],
  },
  {
    label: lang === 'es' ? 'Bases de datos' : 'Databases',
    items: [
      { name: 'MySQL',      icon: 'devicon-mysql-plain colored' },
      { name: 'PostgreSQL', icon: 'devicon-postgresql-plain colored' },
      { name: 'SQL Server', icon: 'devicon-microsoftsqlserver-plain colored' },
    ],
  },
  {
    label: 'DevOps',
    items: [
      { name: 'Docker', icon: 'devicon-docker-plain colored' },
      { name: 'Nginx',  icon: 'devicon-nginx-plain colored' },
      { name: 'Linux',  icon: 'devicon-linux-plain colored' },
      { name: 'Git',    icon: 'devicon-git-plain colored' },
      { name: 'GitHub', icon: 'devicon-github-original colored' },
      { name: 'GitLab', icon: 'devicon-gitlab-plain colored' },
    ],
  },
  {
    label: lang === 'es' ? 'Diseño' : 'Design',
    items: [
      { name: 'Figma',        icon: 'devicon-figma-plain colored' },
      { name: 'Atomic Design', icon: '' },
    ],
  },
  {
    label: lang === 'es' ? 'Otros' : 'Other',
    items: [
      { name: 'OpenPay',   icon: '' },
      { name: 'ReportLab', icon: '' },
      { name: 'SCRUM',     icon: '' },
    ],
  },
];
---

<section id="about" class="section about-section">
  <div class="container">
    <h2
      class="section-title mb-4"
      data-reveal
      style="--reveal-delay: 0s"
    >{t('about.title')}</h2>

    <div class="row g-5 align-items-start">
      <!-- Text -->
      <div class="col-lg-6" data-reveal style="--reveal-delay: 0.1s">
        <p class="about-text">
          {t('about.text')}
        </p>
      </div>

      <!-- Stack -->
      <div class="col-lg-6" data-reveal style="--reveal-delay: 0.25s">
        <div class="card">
          {stackGroups.map((group) => (
            <div>
              <p class="stack-group-title">{group.label}</p>
              <div class="chips-wrap">
                {group.items.map((item) => (
                  <span class="chip">
                    {item.icon && <i class={item.icon}></i>}
                    {item.name}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
